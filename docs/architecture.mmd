flowchart TB
    subgraph Clients
      OA[OpenAI agent]
      CL[Claude agent]
      GM[Gemini agent]
      HU[Human operator]
    end

    subgraph ControlPlane
      GW[Browser tool gateway / MCP server]
      Policy[Policy engine]
      Queue[Approval queue]
      Meta[(Redis / Postgres)]
    end

    subgraph BrowserPlane
      B1[Browser pod A]
      B2[Browser pod B]
      B3[Browser pod N]
    end

    subgraph Storage
      Art[(Screenshots / traces / videos)]
      Secrets[(Secrets manager)]
      Auth[(Encrypted auth state)]
    end

    OA --> GW
    CL --> GW
    GM --> GW
    HU --> Queue
    HU --> B1
    GW --> Policy
    Policy --> Queue
    GW --> Meta
    GW --> B1
    GW --> B2
    GW --> B3
    B1 --> Art
    B2 --> Art
    B3 --> Art
    GW --> Auth
    GW --> Secrets
